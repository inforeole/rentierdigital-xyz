{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.rentierdigital.xyz" }],
      "destination": "https://rentierdigital.xyz/:path",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/prompt-contracts-cover-(.*).avif",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
