{
  "buildCommand": "bun --bun run build",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.rentierdigital.xyz" }],
      "destination": "https://rentierdigital.xyz/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/go/:slug",
      "destination": "https://convexrentienr-actions.neoracines.com/api/go/:slug"
    }
  ],
  "headers": [
    {
      "source": "/prompt-contracts-cover-(.*).avif",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/vibe-coding-cover(.*).avif",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
