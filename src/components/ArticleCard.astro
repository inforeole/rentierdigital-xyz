---
interface Props {
  title: string;
  slug: string;
  hook?: string | null;
  themes: string[];
  publishedDate?: string | null;
  readTime?: number | null;
  lang?: string;
}

const { title, slug, hook, themes, publishedDate, readTime, lang } = Astro.props;
const blogPrefix = lang && lang !== "en" ? `/${lang}/blog` : "/blog";
---

<a
  href={`${blogPrefix}/${slug}`}
  class="group block rounded-lg border border-white/10 p-5 transition-colors hover:border-white/20"
>
  <h3
    class="text-lg font-semibold text-white transition-colors group-hover:text-blue-400"
  >
    {title}
  </h3>
  {hook && <p class="mt-2 line-clamp-2 text-sm text-neutral-400">{hook}</p>}
  <div class="mt-3 flex flex-wrap items-center gap-2">
    {
      themes.slice(0, 3).map((theme) => (
        <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-xs text-neutral-400">
          {theme}
        </span>
      ))
    }
    {
      publishedDate && (
        <span class="ml-auto text-xs text-neutral-400">{publishedDate}</span>
      )
    }
    {
      readTime && (
        <span class="text-xs text-neutral-400">{readTime} min read</span>
      )
    }
  </div>
</a>
