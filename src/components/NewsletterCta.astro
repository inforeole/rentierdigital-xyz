---
// Inline newsletter CTA — static block (not popup)
// Desktop: sidebar right column (sticky)
// Mobile: full-width before footer
interface Props {
  utmCampaign?: string;
}
const { utmCampaign = "blog" } = Astro.props;
const href = `https://rentierdigital.beehiiv.com/subscribe?utm_source=astro&utm_medium=sidebar&utm_campaign=${utmCampaign}`;
---

<aside class="rounded-xl border border-white/10 bg-[#111] p-5">
  <div class="text-center">
    <div class="mb-2 text-2xl">⚡</div>
    <h3 class="text-lg font-bold text-white">The Agent Engineering Stack</h3>
    <p class="mt-2 text-sm text-neutral-400">
      3 production-tested blueprints to ship AI agents that actually work. Free.
    </p>
  </div>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-4 block w-full rounded-lg bg-blue-600 px-4 py-2.5 text-center text-sm font-semibold text-white transition-colors hover:bg-blue-500"
  >
    Get the Stack →
  </a>
  <p class="mt-2 text-center text-xs text-neutral-500">
    One email per week. Unsubscribe anytime.
  </p>
</aside>
