---
const navItems = [
  { href: "/blog", label: "Blog" },
  { href: "/tools", label: "Tools" },
  { href: "/about", label: "About" },
];

const langs = [
  { code: "en", label: "EN", prefix: "" },
  { code: "fr", label: "FR", prefix: "/fr" },
  { code: "es", label: "ES", prefix: "/es" },
  { code: "de", label: "DE", prefix: "/de" },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-md"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="text-lg font-bold tracking-tight text-white">
      Rentier Digital
    </a>

    <div class="flex items-center gap-6">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm text-neutral-400 transition-colors hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
      <div id="search" class="hidden sm:block"></div>
      <div class="relative" id="lang-switcher">
        <button
          class="text-sm text-neutral-400 transition-colors hover:text-white"
          aria-label="Language"
          id="lang-toggle"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
        </button>
        <div class="absolute right-0 top-full hidden bg-[#1a1a1a] border border-white/10 rounded-md py-1 min-w-[80px] z-50" id="lang-menu">
          {langs.map((l) => (
            <a
              href={`${l.prefix}/blog`}
              class="block px-3 py-1.5 text-sm text-neutral-400 hover:text-white hover:bg-white/5 transition-colors"
            >
              {l.label}
            </a>
          ))}
        </div>
      </div>
      <script>
        const toggle = document.getElementById('lang-toggle');
        const menu = document.getElementById('lang-menu');
        toggle?.addEventListener('click', (e) => {
          e.stopPropagation();
          menu?.classList.toggle('hidden');
        });
        document.addEventListener('click', () => menu?.classList.add('hidden'));
      </script>
    </div>
  </nav>
</header>
