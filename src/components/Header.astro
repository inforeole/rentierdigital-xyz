---
const navItems = [
  { href: "/blog", label: "Blog" },
  { href: "/tools", label: "Tools" },
  { href: "/about", label: "About" },
];
---

<header
  class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-md"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="text-lg font-bold tracking-tight text-white">
      Rentier Digital
    </a>

    <div class="flex items-center gap-6">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm text-neutral-400 transition-colors hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
      <div id="search" class="hidden sm:block"></div>
    </div>
  </nav>
</header>
