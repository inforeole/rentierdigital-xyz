---
interface Props {
  currentPage: number;
  totalPages: number;
  basePath?: string;
}

const { currentPage, totalPages, basePath = "/blog" } = Astro.props;

function pageUrl(page: number): string {
  if (page === 1) return basePath;
  return `${basePath}/page/${page}`;
}

function pageNumbers(current: number, total: number): (number | "...")[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | "...")[] = [1];
  if (current > 3) pages.push("...");
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push("...");
  pages.push(total);
  return pages;
}
---

{
  totalPages > 1 && (
    <nav class="flex items-center justify-center gap-2 pt-8" aria-label="Pagination">
      {currentPage > 1 ? (
        <a
          href={pageUrl(currentPage - 1)}
          class="rounded-md border border-white/10 px-3 py-2 text-sm text-neutral-400 transition-colors hover:border-white/20 hover:text-white"
          rel="prev"
        >
          &larr;
        </a>
      ) : (
        <span class="rounded-md border border-white/5 px-3 py-2 text-sm text-neutral-600" aria-disabled="true">
          &larr;
        </span>
      )}

      {pageNumbers(currentPage, totalPages).map((p) =>
        p === "..." ? (
          <span class="px-2 text-sm text-neutral-600">&hellip;</span>
        ) : p === currentPage ? (
          <span class="rounded-md bg-white/10 px-3 py-2 text-sm font-medium text-white" aria-current="page">
            {p}
          </span>
        ) : (
          <a
            href={pageUrl(p)}
            class="rounded-md border border-white/10 px-3 py-2 text-sm text-neutral-400 transition-colors hover:border-white/20 hover:text-white"
          >
            {p}
          </a>
        )
      )}

      {currentPage < totalPages ? (
        <a
          href={pageUrl(currentPage + 1)}
          class="rounded-md border border-white/10 px-3 py-2 text-sm text-neutral-400 transition-colors hover:border-white/20 hover:text-white"
          rel="next"
        >
          &rarr;
        </a>
      ) : (
        <span class="rounded-md border border-white/5 px-3 py-2 text-sm text-neutral-600" aria-disabled="true">
          &rarr;
        </span>
      )}
    </nav>
  )
}
