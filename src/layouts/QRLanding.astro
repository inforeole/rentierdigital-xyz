---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  githubUrl: string;
  ctaText: string;
}

const { title, description, githubUrl, ctaText } = Astro.props;
const bookUrl = "https://amazon.com/dp/PLACEHOLDER";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title} — Prompt Contracts</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <script
      defer
      data-domain="rentierdigital.xyz"
      src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-neutral-200 antialiased flex flex-col items-center justify-center px-4 py-8">
    <div class="w-full max-w-[540px] bg-[#161616] border border-neutral-800 rounded-xl p-8 text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-wider text-violet-400 bg-violet-400/10 border border-violet-400/20 rounded-full px-3 py-1 mb-5">
        Prompt Contracts
      </span>

      <h1 class="text-2xl font-bold text-white mb-3 leading-tight">{title}</h1>
      <p class="text-[0.95rem] leading-relaxed text-neutral-400 mb-6">{description}</p>

      <div class="mb-6">
        <slot />
      </div>

      <a
        href={githubUrl}
        class="block w-full text-center font-semibold text-white bg-violet-600 hover:bg-violet-700 rounded-lg py-3.5 transition-colors mb-4 no-underline"
        target="_blank"
        rel="noopener"
        data-action="cta-click"
        data-page={title}
      >
        {ctaText}
      </a>

      <hr class="border-neutral-800 my-5" />

      <a href={bookUrl} class="text-sm text-violet-400 hover:underline no-underline" data-action="book-click">
        Get the book on Amazon (paperback & Kindle)
      </a>
    </div>

    <p class="mt-5 text-xs text-neutral-600">&copy; rentierdigital</p>

    <script is:inline>
      document.addEventListener("click", function (e) {
        var link = e.target.closest("[data-action]");
        if (!link || !window.plausible) return;
        window.plausible(link.dataset.action, {
          props: { page: link.dataset.page || document.title },
        });
      });
    </script>
  </body>
</html>
