---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  githubUrl: string;
  ctaText: string;
  trackSlug?: string;
  brand?: string;
}

const { title, description, githubUrl, ctaText, trackSlug, brand = "Prompt Contracts" } = Astro.props;
const qrTrackUrl = (import.meta.env.PUBLIC_CONVEX_ACTIONS_URL || "") + "/api/qr/track";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title} — {brand}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-neutral-200 antialiased flex flex-col items-center justify-center px-4 py-8">
    <div class="w-full max-w-[540px] bg-[#161616] border border-neutral-800 rounded-xl p-8 text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-wider text-violet-400 bg-violet-400/10 border border-violet-400/20 rounded-full px-3 py-1 mb-5">
        {brand}
      </span>

      <h1 class="text-2xl font-bold text-white mb-3 leading-tight">{title}</h1>
      <p class="text-[0.95rem] leading-relaxed text-neutral-400 mb-6">{description}</p>

      <div class="mb-6">
        <slot />
      </div>

      <a
        href={githubUrl}
        class="block w-full text-center font-semibold text-white bg-violet-600 hover:bg-violet-700 rounded-lg py-3.5 transition-colors no-underline"
        target="_blank"
        rel="noopener"
        data-action="cta-click"
        data-page={title}
      >
        {ctaText}
      </a>
    </div>

    <!-- Newsletter block -->
    <div class="w-full max-w-[540px] mt-4 bg-gradient-to-br from-emerald-950/60 to-emerald-900/30 border border-emerald-700/30 rounded-xl p-6">
      <div class="flex items-center gap-5">
        <img src="/prompt-contracts-cover-thumb.avif" alt="Prompt Contracts" class="w-20 h-auto rounded-md shadow-lg flex-shrink-0" />
        <div class="text-left">
          <h2 class="text-lg font-bold text-emerald-300 mb-1">Level up your builds</h2>
          <p class="text-sm text-neutral-400 mb-3">
            Weekly tips on AI tools, solo building, and shipping faster. No fluff.
          </p>
          <a
            href="https://rentierdigital.beehiiv.com"
            class="inline-block font-semibold text-white bg-emerald-600 hover:bg-emerald-500 rounded-lg px-6 py-2.5 transition-colors no-underline text-sm"
            target="_blank"
            rel="noopener"
            data-action="newsletter-click"
          >
            Subscribe — it's free
          </a>
        </div>
      </div>
    </div>

    <p class="mt-5 text-xs text-neutral-400">&copy; rentierdigital</p>

    <script define:vars={{ qrTrackUrl, trackSlug }}>
      fetch(qrTrackUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug: trackSlug || location.pathname.split("/").pop() })
      }).catch(function(){});
    </script>
  </body>
</html>
