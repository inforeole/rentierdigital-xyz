---
/**
 * Minimal HTML layout served when an article is in `prepa_medium` status.
 *
 * Goal: Medium's "Import a story" parser picks up title, subtitle, body,
 * lists, blockquotes, and links cleanly. The rich Astro template confuses
 * the parser (loses subtitle, strips links inside <em><blockquote>).
 *
 * The URL stays the same as the published version so the canonical
 * Medium attaches points to the right page once the article is published.
 */
interface Props {
  title: string;
  subtitle?: string;
  description: string;
  canonical: string;
  htmlContent: string;
  coverImageUrl?: string;
  coverImageAlt?: string;
  publishedDate?: string;
  lang?: string;
}

const {
  title,
  subtitle,
  description,
  canonical,
  htmlContent,
  coverImageUrl,
  coverImageAlt,
  publishedDate,
  lang = "en",
} = Astro.props;

function escapeHtml(text: string): string {
  return text
    .replace(/&/g, "&amp;")
    .replace(/"/g, "&quot;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");
}

// Insert the cover image right after the TLDR paragraph so the Medium reader
// gets context (title → subtitle → TLDR → cover → body). When no TLDR is
// present (rare), fall back to inserting it at the top of the content.
function insertCoverAfterTldr(html: string, coverUrl: string, altText: string): string {
  const img = `<figure><img src="${coverUrl}" alt="${escapeHtml(altText)}" /></figure>`;
  // Match a paragraph that starts with **TLDR**/**TL;DR** (any colon placement).
  // The markdown renderer outputs `<p><strong>TLDR:</strong> ...</p>` or
  // `<p><strong>TL;DR</strong>: ...</p>`. Match until the closing </p>.
  const tldrParagraph = /<p>\s*<strong>TL;?DR:?<\/strong>:?[\s\S]*?<\/p>/i;
  if (tldrParagraph.test(html)) {
    return html.replace(tldrParagraph, (m) => `${m}\n${img}`);
  }
  // Also accept the H2 form (## TL;DR) rendered as <h2>TL;DR</h2><p>…</p>
  const tldrHeading = /<h2[^>]*>\s*TL;?DR\s*<\/h2>\s*<p>[\s\S]*?<\/p>/i;
  if (tldrHeading.test(html)) {
    return html.replace(tldrHeading, (m) => `${m}\n${img}`);
  }
  return `${img}\n${html}`;
}

const renderedHtml = coverImageUrl
  ? insertCoverAfterTldr(htmlContent, coverImageUrl, coverImageAlt ?? title)
  : htmlContent;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {coverImageUrl && <meta property="og:image" content={coverImageUrl} />}
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    <meta name="robots" content="noindex, follow" />
  </head>
  <body>
    <article>
      <h1>{title}</h1>
      {subtitle && <h4>{subtitle}</h4>}
      <div set:html={renderedHtml} />
    </article>
  </body>
</html>
