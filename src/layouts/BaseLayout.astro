---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import NewsletterPopup from "../components/NewsletterPopup.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  lang?: string;
  slug?: string;
  translations?: { lang: string; slug: string; title: string }[];
  preloadImage?: string;
  hideNewsletterPopup?: boolean;
}

const props = Astro.props;
const htmlLang = props.lang || "en";
---

<!doctype html>
<html lang={htmlLang} class="dark">
  <head>
    <BaseHead {...props} />
    <script
      defer
      data-domain="rentierdigital.xyz"
      src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-neutral-200 antialiased">
    <Header />
    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>
    <Footer />
    {!props.hideNewsletterPopup && <NewsletterPopup />}
  </body>
</html>
