---
import BaseLayout from "./BaseLayout.astro";
import RelatedArticles from "../components/RelatedArticles.astro";
import NewsletterCta from "../components/NewsletterCta.astro";
import type { ContentListItem } from "../types/content";

interface Props {
  title: string;
  subtitle?: string;
  seoTitle?: string;
  description: string;
  publishedDate?: string;
  readTime?: number;
  tags: string[];
  canonical: string;
  htmlContent: string;
  related: ContentListItem[];
  seoSchemaJsonld?: string;
  seoTargetKeyword?: string;
  coverImageUrl?: string;
  coverImageAlt?: string;
  coverCaption?: string;
  hideCoverImage?: boolean;
  lang?: string;
  slug?: string;
  translations?: { lang: string; slug: string; title: string }[];
  preloadImage?: string;
  updatedAt?: string | null;
}

const {
  title,
  subtitle,
  seoTitle,
  description,
  publishedDate,
  readTime,
  tags,
  canonical,
  htmlContent,
  related,
  seoSchemaJsonld,
  seoTargetKeyword,
  coverImageUrl,
  coverImageAlt,
  coverCaption,
  hideCoverImage = false,
  lang,
  slug,
  translations,
  preloadImage,
  updatedAt,
} = Astro.props;

// Compute real dateModified from updated_at or fall back to publishedDate
// dateModified must always be >= datePublished for valid JSON-LD
const rawModified = updatedAt
  ? new Date(updatedAt).toISOString().split("T")[0]
  : publishedDate;
const dateModified = (publishedDate && rawModified < publishedDate) ? publishedDate : rawModified;

// LCP image preload: inline image if cover hidden, otherwise cover
const lcpPreload = preloadImage
  ? preloadImage.replace(/\.\w+$/, "-480w.avif")
  : (!hideCoverImage && coverImageUrl)
    ? coverImageUrl.replace(/\.\w+$/, "-480w.avif")
    : undefined;

// Escape HTML special chars for safe use in attributes and content
function escapeHtml(text: string): string {
  return text.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

let processedHtml = htmlContent;
// Style first bold paragraph as subtitle (same sans-serif font as h1)
// Use function replacement to avoid $N backreference interpretation in content
processedHtml = processedHtml.replace(
  /^(\s*<p><strong>)([\s\S]*?)(<\/strong><\/p>)/i,
  (_match, _p1, p2) => `<p class="subtitle">${p2}</p>`
);
// Transform TLDR into styled box — handles both blockquote and plain paragraph
// Function replacements prevent $N in content from being interpreted as backreferences
processedHtml = processedHtml
  // Case 1: TLDR inside a blockquote → replace blockquote with tldr-box div
  .replace(
    /<blockquote>\s*(<p><strong>TL;?DR:?<\/strong>[\s\S]*?)<\/blockquote>/i,
    (_match, p1) => `<div class="tldr-box">${p1}</div>`
  )
  // Case 2: TLDR as a plain paragraph → wrap in tldr-box div
  .replace(
    /(?<!<div class="tldr-box">)(<p><strong>TL;?DR:?<\/strong>[\s\S]*?<\/p>)/i,
    (_match, p1) => `<div class="tldr-box">${p1}</div>`
  );

// Strip <figure data-cover> only when layout will render its own optimized <picture>.
// When hideCoverImage is true, the inline figure IS the cover — keep it.
if (!hideCoverImage) {
  processedHtml = processedHtml.replace(
    /<figure\s+data-cover[^>]*>[\s\S]*?<\/figure>/gi,
    ''
  );
  // Move infographic figures out of the intro (before first <h2>) to avoid
  // stacking cover + infographic. Relocate them right after the first <h2> block.
  const h2Pos = processedHtml.indexOf('<h2');
  if (h2Pos > -1) {
    const intro = processedHtml.slice(0, h2Pos);
    const rest = processedHtml.slice(h2Pos);
    const infographicRe = /<figure\s+data-source="infographic"[^>]*>[\s\S]*?<\/figure>/gi;
    const infographics: string[] = [];
    const cleanedIntro = intro.replace(infographicRe, (match) => { infographics.push(match); return ''; });
    if (infographics.length > 0) {
      // Insert after the closing tag of the first <h2>...</h2>
      const afterH2 = rest.replace(/(<\/h2>)/, (m) => `${m}\n${infographics.join('\n')}`);
      processedHtml = cleanedIntro + afterH2;
    }
  }
}

// Inject cover image after TL;DR box (with italic caption)
if (coverImageUrl && !hideCoverImage) {
  const altText = escapeHtml(coverImageAlt || title);
  const isSvgOrGif = /\.(svg|gif)$/i.test(coverImageUrl);
  const imgTag = isSvgOrGif
    ? `<img src="${coverImageUrl}" alt="${altText}" width="768" height="432" class="w-full rounded-lg border border-white/10 object-cover" fetchpriority="high" />`
    : `<picture><source srcset="${coverImageUrl.replace(/\.\w+$/, '-480w.avif')} 480w, ${coverImageUrl.replace(/\.\w+$/, '.avif')} 768w" type="image/avif" sizes="(max-width: 768px) 100vw, 662px" /><source srcset="${coverImageUrl}" type="image/${coverImageUrl.match(/\.(\w+)$/)?.[1] === 'jpg' ? 'jpeg' : coverImageUrl.match(/\.(\w+)$/)?.[1] || 'png'}" /><img src="${coverImageUrl}" alt="${altText}" width="768" height="432" sizes="(max-width: 768px) 100vw, 662px" class="w-full rounded-lg border border-white/10 object-cover" fetchpriority="high" /></picture>`;
  const captionText = coverCaption || coverImageAlt;
  const captionHtml = captionText
    ? `<figcaption class="mt-2 text-center text-sm italic text-neutral-400">${escapeHtml(captionText)}</figcaption>`
    : '';
  const figureHtml = `<figure class="my-8">${imgTag}${captionHtml}</figure>`;

  if (processedHtml.includes('class="tldr-box"')) {
    processedHtml = processedHtml.replace(
      /(<div class="tldr-box">[\s\S]*?<\/div>)/i,
      (match) => `${match}\n${figureHtml}`
    );
  } else {
    // Fallback: insert before the first h2
    const h2Index = processedHtml.indexOf('<h2');
    if (h2Index > -1) {
      processedHtml = processedHtml.slice(0, h2Index) + figureHtml + processedHtml.slice(h2Index);
    } else {
      processedHtml = figureHtml + processedHtml;
    }
  }
}

// Build full cover image URL for meta tags
const fullCoverImage = coverImageUrl
  ? (coverImageUrl.startsWith("http") ? coverImageUrl : new URL(coverImageUrl, Astro.site).href)
  : undefined;

// Use custom JSON-LD from SEO pipeline if available, otherwise build complete one
const jsonLd = seoSchemaJsonld
  ? JSON.parse(seoSchemaJsonld)
  : {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      datePublished: publishedDate,
      dateModified: dateModified,
      ...(fullCoverImage ? { image: [fullCoverImage] } : {}),
      author: {
        "@type": "Person",
        name: "Phil",
        url: "https://rentierdigital.xyz/about",
      },
      publisher: {
        "@type": "Organization",
        name: "Rentier Digital",
        url: "https://rentierdigital.xyz",
        logo: {
          "@type": "ImageObject",
          url: "https://rentierdigital.xyz/favicon.png",
        },
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonical,
      },
    };
// Ensure @context and required fields are always present
if (!jsonLd["@context"]) jsonLd["@context"] = "https://schema.org";
if (!jsonLd.mainEntityOfPage) jsonLd.mainEntityOfPage = { "@type": "WebPage", "@id": canonical };
if (!jsonLd.dateModified && jsonLd.datePublished) jsonLd.dateModified = jsonLd.datePublished;
if (jsonLd.dateModified && jsonLd.datePublished && jsonLd.dateModified < jsonLd.datePublished) jsonLd.dateModified = jsonLd.datePublished;
if (!jsonLd.image && fullCoverImage) jsonLd.image = [fullCoverImage];
if (!jsonLd.publisher?.logo) {
  jsonLd.publisher = { ...jsonLd.publisher, logo: { "@type": "ImageObject", url: "https://rentierdigital.xyz/favicon.png" } };
}
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  canonical={canonical}
  ogImage={fullCoverImage}
  ogType="article"
  publishedTime={publishedDate}
  lang={lang}
  slug={slug}
  translations={translations}
  preloadImage={lcpPreload}
>
  <div class="mx-auto max-w-5xl lg:grid lg:grid-cols-[1fr_280px] lg:gap-10">
    <article class="max-w-3xl">
      <header class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {title}
        </h1>
        {subtitle && (
          <h2 class="mt-3 text-lg font-normal italic text-neutral-400 sm:text-xl">
            {subtitle}
          </h2>
        )}
        <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-neutral-400">
          {publishedDate && <time datetime={publishedDate}>{publishedDate}</time>}
          {readTime && <span>{readTime} min read</span>}
        </div>
      </header>

      <div
        class="prose prose-lg prose-invert max-w-none prose-headings:text-white prose-a:text-blue-400 prose-code:text-neutral-300 prose-pre:bg-[#111] prose-pre:border prose-pre:border-white/10 prose-img:rounded-lg prose-img:border prose-img:border-white/10"
        set:html={processedHtml}
      />

      <!-- Mobile: CTA before related articles -->
      <div class="mt-10 lg:hidden">
        <NewsletterCta />
      </div>

      <RelatedArticles articles={related} lang={lang} />
    </article>

    <!-- Desktop: sticky sidebar -->
    <aside class="hidden lg:block">
      <div class="sticky top-24">
        <NewsletterCta />
      </div>
    </aside>
  </div>

  {seoTargetKeyword && <meta name="keywords" content={seoTargetKeyword} />}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://rentierdigital.xyz/" },
      { "@type": "ListItem", position: 2, name: "Blog", item: `https://rentierdigital.xyz${lang && lang !== "en" ? `/${lang}` : ""}/blog` },
      { "@type": "ListItem", position: 3, name: title },
    ],
  })} />
</BaseLayout>
