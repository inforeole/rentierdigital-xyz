---
import BaseLayout from "./BaseLayout.astro";
import RelatedArticles from "../components/RelatedArticles.astro";
import type { ContentListItem } from "../types/content";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  publishedDate?: string;
  readTime?: number;
  themes: string[];
  canonical: string;
  htmlContent: string;
  related: ContentListItem[];
  seoSchemaJsonld?: string;
  seoTargetKeyword?: string;
  coverImageUrl?: string;
  coverImageAlt?: string;
  hideCoverImage?: boolean;
  lang?: string;
  translations?: { lang: string; slug: string; title: string }[];
  preloadImage?: string;
}

const {
  title,
  seoTitle,
  description,
  publishedDate,
  readTime,
  themes,
  canonical,
  htmlContent,
  related,
  seoSchemaJsonld,
  seoTargetKeyword,
  coverImageUrl,
  coverImageAlt,
  hideCoverImage = false,
  lang,
  translations,
  preloadImage,
} = Astro.props;

// LCP image preload: inline image if cover hidden, otherwise cover
const lcpPreload = preloadImage
  ? preloadImage.replace(/\.\w+$/, "-480w.avif")
  : (!hideCoverImage && coverImageUrl)
    ? coverImageUrl.replace(/\.\w+$/, "-480w.avif")
    : undefined;

// Strip <hr> tags — layout handles spacing, markdown --- separators are noise
let processedHtml = htmlContent.replace(/<hr\s*\/?>/gi, '');
// Transform TLDR into styled box — handles both blockquote and plain paragraph
processedHtml = processedHtml
  // Case 1: TLDR inside a blockquote → replace blockquote with tldr-box div
  .replace(
    /<blockquote>\s*(<p><strong>TL;DR:?<\/strong>[\s\S]*?)<\/blockquote>/i,
    '<div class="tldr-box">$1</div>'
  )
  // Case 2: TLDR as a plain paragraph → wrap in tldr-box div
  .replace(
    /(?<!<div class="tldr-box">)(<p><strong>TL;DR:?<\/strong>[\s\S]*?<\/p>)/i,
    '<div class="tldr-box">$1</div>'
  );

// Inject cover image after TL;DR box (with italic caption)
if (coverImageUrl && !hideCoverImage) {
  const altText = coverImageAlt || title;
  const isSvgOrGif = /\.(svg|gif)$/i.test(coverImageUrl);
  const imgTag = isSvgOrGif
    ? `<img src="${coverImageUrl}" alt="${altText}" width="768" height="432" class="w-full rounded-lg border border-white/10 object-cover" fetchpriority="high" />`
    : `<picture><source srcset="${coverImageUrl.replace(/\.\w+$/, '-480w.avif')} 480w, ${coverImageUrl.replace(/\.\w+$/, '.avif')} 768w" type="image/avif" sizes="(max-width: 768px) 100vw, 662px" /><img src="${coverImageUrl}" alt="${altText}" width="768" height="432" sizes="(max-width: 768px) 100vw, 662px" class="w-full rounded-lg border border-white/10 object-cover" fetchpriority="high" /></picture>`;
  const captionHtml = coverImageAlt
    ? `<figcaption class="mt-2 text-center text-sm italic text-neutral-500">${coverImageAlt}</figcaption>`
    : '';
  const figureHtml = `<figure class="my-8">${imgTag}${captionHtml}</figure>`;

  if (processedHtml.includes('class="tldr-box"')) {
    processedHtml = processedHtml.replace(
      /(<div class="tldr-box">[\s\S]*?<\/div>)/i,
      `$1\n${figureHtml}`
    );
  } else {
    // Fallback: insert before the first h2
    const h2Index = processedHtml.indexOf('<h2');
    if (h2Index > -1) {
      processedHtml = processedHtml.slice(0, h2Index) + figureHtml + processedHtml.slice(h2Index);
    } else {
      processedHtml = figureHtml + processedHtml;
    }
  }
}

// Build full cover image URL for meta tags
const fullCoverImage = coverImageUrl
  ? (coverImageUrl.startsWith("http") ? coverImageUrl : new URL(coverImageUrl, Astro.site).href)
  : undefined;

// Use custom JSON-LD from SEO pipeline if available, otherwise build complete one
const jsonLd = seoSchemaJsonld
  ? JSON.parse(seoSchemaJsonld)
  : {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      description,
      datePublished: publishedDate,
      dateModified: publishedDate,
      ...(fullCoverImage ? { image: [fullCoverImage] } : {}),
      author: {
        "@type": "Person",
        name: "Phil",
        url: "https://rentierdigital.xyz/about",
      },
      publisher: {
        "@type": "Organization",
        name: "Rentier Digital",
        url: "https://rentierdigital.xyz",
        logo: {
          "@type": "ImageObject",
          url: "https://rentierdigital.xyz/favicon.png",
        },
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonical,
      },
    };
// Ensure @context and required fields are always present
if (!jsonLd["@context"]) jsonLd["@context"] = "https://schema.org";
if (!jsonLd.mainEntityOfPage) jsonLd.mainEntityOfPage = { "@type": "WebPage", "@id": canonical };
if (!jsonLd.dateModified && jsonLd.datePublished) jsonLd.dateModified = jsonLd.datePublished;
if (!jsonLd.image && fullCoverImage) jsonLd.image = [fullCoverImage];
if (!jsonLd.publisher?.logo) {
  jsonLd.publisher = { ...jsonLd.publisher, logo: { "@type": "ImageObject", url: "https://rentierdigital.xyz/favicon.png" } };
}
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  canonical={canonical}
  ogImage={fullCoverImage}
  ogType="article"
  publishedTime={publishedDate}
  lang={lang}
  translations={translations}
  preloadImage={lcpPreload}
>
  <article class="mx-auto max-w-3xl">
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-neutral-400">
        {publishedDate && <time datetime={publishedDate}>{publishedDate}</time>}
        {readTime && <span>{readTime} min read</span>}
      </div>
      {
        themes.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {themes.map((theme) => (
              <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-xs text-neutral-400">
                {theme}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <div
      class="prose prose-lg prose-invert max-w-none prose-headings:text-white prose-a:text-blue-400 prose-code:text-neutral-300 prose-pre:bg-[#111] prose-pre:border prose-pre:border-white/10 prose-img:rounded-lg prose-img:border prose-img:border-white/10"
      set:html={processedHtml}
    />

    <RelatedArticles articles={related} lang={lang} />
  </article>

  {seoTargetKeyword && <meta name="keywords" content={seoTargetKeyword} />}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
