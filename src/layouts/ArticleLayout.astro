---
import BaseLayout from "./BaseLayout.astro";
import RelatedArticles from "../components/RelatedArticles.astro";
import type { ContentListItem } from "../types/content";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  publishedDate?: string;
  readTime?: number;
  themes: string[];
  canonical: string;
  htmlContent: string;
  related: ContentListItem[];
  seoSchemaJsonld?: string;
  seoTargetKeyword?: string;
  coverImageUrl?: string;
  coverImageAlt?: string;
  lang?: string;
  translations?: { lang: string; slug: string; title: string }[];
}

const {
  title,
  seoTitle,
  description,
  publishedDate,
  readTime,
  themes,
  canonical,
  htmlContent,
  related,
  seoSchemaJsonld,
  seoTargetKeyword,
  coverImageUrl,
  coverImageAlt,
  lang,
  translations,
} = Astro.props;

// Use custom JSON-LD from SEO pipeline if available, otherwise default
const jsonLd = seoSchemaJsonld
  ? JSON.parse(seoSchemaJsonld)
  : {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      description,
      datePublished: publishedDate,
      author: {
        "@type": "Person",
        name: "Phil",
        url: "https://rentierdigital.xyz/about",
      },
      publisher: {
        "@type": "Organization",
        name: "Rentier Digital",
        url: "https://rentierdigital.xyz",
      },
    };
// Ensure @context is always present
if (!jsonLd["@context"]) jsonLd["@context"] = "https://schema.org";
---

<BaseLayout
  title={`${seoTitle ?? title} — Rentier Digital`}
  description={description}
  canonical={canonical}
  ogType="article"
  publishedTime={publishedDate}
  lang={lang}
  translations={translations}
>
  <article class="mx-auto max-w-3xl">
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-neutral-400">
        {publishedDate && <time datetime={publishedDate}>{publishedDate}</time>}
        {readTime && <span>{readTime} min read</span>}
      </div>
      {
        themes.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {themes.map((theme) => (
              <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-xs text-neutral-400">
                {theme}
              </span>
            ))}
          </div>
        )
      }
    </header>

    {
      coverImageUrl && (
        <img
          src={coverImageUrl}
          alt={coverImageAlt || title}
          class="mb-8 w-full rounded-lg border border-white/10 object-cover"
        />
      )
    }

    <div
      class="prose prose-invert max-w-none prose-headings:text-white prose-a:text-blue-400 prose-code:text-neutral-300 prose-pre:bg-[#111] prose-pre:border prose-pre:border-white/10"
      set:html={htmlContent}
    />

    <RelatedArticles articles={related} lang={lang} />
  </article>

  {seoTargetKeyword && <meta name="keywords" content={seoTargetKeyword} />}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
