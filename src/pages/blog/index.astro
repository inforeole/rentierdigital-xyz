---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import Pagination from "../../components/Pagination.astro";
import NewsletterCta from "../../components/NewsletterCta.astro";
import { getBlogList } from "../../lib/convex";

const PAGE_SIZE = 12;

const articles = await getBlogList();
const sortDate = (a: (typeof articles)[0]) =>
  a.published_date ? new Date(a.published_date).getTime() : a._creationTime;
articles.sort((a, b) => sortDate(b) - sortDate(a));

const totalPages = Math.ceil(articles.length / PAGE_SIZE);
const pageArticles = articles.slice(0, PAGE_SIZE);
---

<BaseLayout
  title="Blog — Rentier Digital"
  description="Articles on building with AI, prompt engineering, solo building, and shipping real products."
>
  <h1 class="mb-8 text-3xl font-bold text-white">Blog</h1>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      pageArticles.map((article) => (
        <ArticleCard
          title={article.title}
          slug={article.slug}
          hook={article.hook_first_lines}
          tags={article.tags}
          publishedDate={article.published_date}
          readTime={article.read_time_minutes}
          lang="en"
          headingLevel="h2"
        />
      ))
    }
  </div>

  <div class="mx-auto mt-10 max-w-md">
    <NewsletterCta utmMedium="blog-listing" />
  </div>

  <Pagination currentPage={1} totalPages={totalPages} />
</BaseLayout>
