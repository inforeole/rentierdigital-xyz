---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getBlogList, getBlogBySlug } from "../../lib/convex";
import { renderMarkdown } from "../../lib/markdown";
import { toLocalImagePath } from "../../lib/image-utils";
import type { ContentListItem } from "../../types/content";

export async function getStaticPaths() {
  const articles = await getBlogList();
  return articles.map((article) => {
    // Pre-compute top 3 related articles by common themes
    const related = articles
      .filter((a) => a.slug !== article.slug)
      .map((a) => ({
        ...a,
        commonThemes: a.themes.filter((t: string) =>
          article.themes.includes(t)
        ).length,
      }))
      .filter((a) => a.commonThemes > 0)
      .sort((a, b) => b.commonThemes - a.commonThemes)
      .slice(0, 3);
    return {
      params: { slug: article.slug },
      props: { related: related as ContentListItem[] },
    };
  });
}

const { slug } = Astro.params;
const { related } = Astro.props;
const content = await getBlogBySlug(slug!);

if (!content) {
  return Astro.redirect("/404");
}

// Strip the first H1 from markdown (layout already renders it)
// Then demote any remaining H1 to H2 — only one H1 per page (the layout title)
const markdownWithoutH1 = content.content_markdown
  .replace(/^#\s+.+\n*/m, "")
  .replace(/^# /gm, "## ")
  .replace(/^\[cover image\]\s*$/gim, "");
const htmlContent = await renderMarkdown(markdownWithoutH1);
// Don't render cover in layout if markdown already has an inline image (avoids duplicate)
const markdownHasInlineImage = /!\[.*?\]\(.*?\)/.test(markdownWithoutH1);
const description =
  content.seo_meta_description ??
  content.hook_first_lines ??
  content.content_markdown.slice(0, 155).replace(/\n/g, " ");
const canonical = `https://rentierdigital.xyz/blog/${content.slug}`;
---

<ArticleLayout
  title={content.title}
  seoTitle={content.seo_meta_title}
  description={description}
  publishedDate={content.published_date}
  readTime={content.read_time_minutes}
  themes={content.themes}
  canonical={canonical}
  htmlContent={htmlContent}
  related={related}
  seoSchemaJsonld={content.seo_schema_jsonld}
  seoTargetKeyword={content.seo_target_keyword}
  coverImageUrl={content.cover_image_url && !markdownHasInlineImage ? toLocalImagePath(content.cover_image_url) : undefined}
  coverImageAlt={content.cover_image_alt}
  lang="en"
  translations={content.translations}
/>
