---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getBlogList, getBlogBySlug } from "../../lib/convex";
import { renderMarkdown } from "../../lib/markdown";
import { toLocalImagePath } from "../../lib/image-utils";
import type { ContentListItem } from "../../types/content";

export async function getStaticPaths() {
  const articles = await getBlogList();
  return articles.map((article) => {
    // Pre-compute top 3 related articles by common themes
    const related = articles
      .filter((a) => a.slug !== article.slug)
      .map((a) => ({
        ...a,
        commonTags: (a.tags ?? []).filter((t: string) =>
          (article.tags ?? []).some((at: string) => at.toLowerCase() === t.toLowerCase())
        ).length,
      }))
      .filter((a) => a.commonTags > 0)
      .sort((a, b) => b.commonTags - a.commonTags)
      .slice(0, 3);
    return {
      params: { slug: article.slug },
      props: { related: related as ContentListItem[] },
    };
  });
}

const { slug } = Astro.params;
const { related } = Astro.props;
const content = await getBlogBySlug(slug!);

if (!content) {
  return Astro.redirect("/404");
}

// Strip the first H1 from markdown (layout already renders it)
// Then demote any remaining H1 to H2 — only one H1 per page (the layout title)
const markdownWithoutH1 = content.content_markdown
  .replace(/^#\s+.+\n*/m, "")
  .replace(/^# /gm, "## ")
  .replace(/^\[cover image\]\s*$/gim, "");
const htmlContent = await renderMarkdown(markdownWithoutH1);
// Don't render cover in layout if markdown already contains the cover image (avoids duplicate)
// Compare by hash (8-char md5 suffix) since cover and inline may have different descriptors
const coverHash = content.cover_image_url?.match(/-([a-f0-9]{8})\.\w+$/)?.[1];
const markdownHasInlineImage = coverHash
  ? markdownWithoutH1.includes(coverHash)
  : content.cover_image_url
    ? markdownWithoutH1.includes(content.cover_image_url)
    : /!\[.*?\]\(.*?\)/.test(markdownWithoutH1);
// Extract first inline image for LCP preload
const firstImageMatch = markdownWithoutH1.match(/!\[(.*?)\]\((https?:\/\/[^)]+)\)/);
const firstInlineImageUrl = firstImageMatch
  ? toLocalImagePath(firstImageMatch[2], firstImageMatch[1] || "Illustration")
  : undefined;
const description = (
  content.seo_meta_description ??
  content.hook_first_lines ??
  content.content_markdown.slice(0, 155).replace(/\n/g, " ")
).trim();
const canonical = `https://rentierdigital.xyz/blog/${content.slug}`;
---

<ArticleLayout
  title={content.title}
  subtitle={content.subtitle}
  seoTitle={content.seo_meta_title}
  description={description}
  publishedDate={content.published_date}
  readTime={content.read_time_minutes}
  tags={content.tags}
  canonical={canonical}
  htmlContent={htmlContent}
  related={related}
  seoSchemaJsonld={content.seo_schema_jsonld}
  seoTargetKeyword={content.seo_target_keyword}
  coverImageUrl={content.cover_image_url ? toLocalImagePath(content.cover_image_url, content.slug) : undefined}
  hideCoverImage={markdownHasInlineImage}
  coverImageAlt={content.cover_image_alt}
  coverCaption={content.cover_caption}
  lang="en"
  translations={content.translations}
  preloadImage={markdownHasInlineImage ? firstInlineImageUrl : undefined}
  updatedAt={content.updated_at}
/>
