---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getBlogList, getBlogBySlug } from "../lib/convex";

const articles = await getBlogList();
articles.sort(
  (a, b) =>
    new Date(b.published_date ?? 0).getTime() -
    new Date(a.published_date ?? 0).getTime()
);

const featured = articles[0] ? await getBlogBySlug(articles[0].slug) : null;
const latest = articles.slice(1, 21);
---

<BaseLayout
  title="Rentier Digital — Build with AI"
  description="Tools, methods, and guides to ship real products with AI. From prompt engineering to production."
>
  <!-- Hero -->
  <section class="py-16">
    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl text-center">
      Build real products<br />
      <span class="text-blue-400">with AI</span>
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-neutral-400 text-center">
      Guides, tools, and methods for solo builders and non-technical founders
      who want to ship — not just prototype.
    </p>
    <div class="mt-8 flex justify-center gap-4 text-center">
      <a
        href="/blog"
        class="rounded-md bg-white px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-neutral-200"
      >
        Read the blog
      </a>
      <a
        href="/tools"
        class="rounded-md border border-white/20 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:border-white/40"
      >
        Explore tools
      </a>
    </div>
  </section>

  <!-- Featured article -->
  {featured && (
    <section class="mx-auto max-w-2xl px-4 pb-12">
      <a
        href={`/blog/${featured.slug}`}
        class="group block rounded-xl border border-white/10 p-6 transition-colors hover:border-blue-400/40 hover:bg-white/[0.02]"
      >
        {featured.cover_image_url && (
          <img
            src={featured.cover_image_url}
            alt={featured.cover_image_alt ?? featured.title}
            class="mb-4 w-full rounded-lg object-cover"
            style="max-height: 280px;"
          />
        )}
        <span class="mb-2 inline-block rounded-full bg-blue-500/10 px-3 py-1 text-xs font-medium text-blue-400">
          Latest article
        </span>
        <h2 class="mt-2 text-2xl font-bold text-white transition-colors group-hover:text-blue-400">
          {featured.title}
        </h2>
        {featured.hook_first_lines && (
          <p class="mt-2 text-neutral-400 line-clamp-3">{featured.hook_first_lines}</p>
        )}
        <div class="mt-4 flex items-center gap-3 text-sm text-neutral-500">
          {featured.published_date && <span>{featured.published_date}</span>}
          {featured.read_time_minutes && <span>{featured.read_time_minutes} min read</span>}
        </div>
      </a>
    </section>
  )}

  <!-- Hacker canvas (desktop only, positioned by JS) -->
  <canvas id="hacker-canvas" class="hidden lg:block rounded-lg" width="480" height="240"></canvas>

  <!-- MOBILE layout: canvas sticky top + articles scrolling below -->
  <div class="lg:hidden">
    <div class="sticky top-4 z-10 bg-[#0a0a0a] px-4 pt-4 pb-6">
      <canvas id="hacker-canvas-mobile" class="rounded-lg w-full" width="480" height="240"></canvas>
    </div>
    <div class="px-4 pb-8">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-xl font-semibold text-white">Latest articles</h2>
        <a href="/blog" class="text-sm text-neutral-400 transition-colors hover:text-white">
          View all &rarr;
        </a>
      </div>
      {latest.map((article) => (
        <div class="mb-4">
          <ArticleCard
            title={article.title}
            slug={article.slug}
            hook={article.hook_first_lines}
            themes={article.themes}
            publishedDate={article.published_date}
            readTime={article.read_time_minutes}
            lang="en"
          />
        </div>
      ))}
    </div>
  </div>

  <!-- DESKTOP layout: fixed canvas + scroll-driven articles -->
  <div id="scroll-section" class="relative hidden lg:block">
    <div class="sticky top-0 h-screen pt-16 overflow-hidden">
      <div class="w-1/2">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-xl font-semibold text-white">Latest articles</h2>
          <a href="/blog" class="text-sm text-neutral-400 transition-colors hover:text-white">
            View all &rarr;
          </a>
        </div>
        <div class="overflow-hidden" style="height: calc(100vh - 140px);">
          <div id="articles-track">
            {latest.map((article) => (
              <div class="mb-4">
                <ArticleCard
                  title={article.title}
                  slug={article.slug}
                  hook={article.hook_first_lines}
                  themes={article.themes}
                  publishedDate={article.published_date}
                  readTime={article.read_time_minutes}
                  lang="en"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const FRAME_COUNT = 120;
    const AUDIO_DURATION = 8;
    const VIDEO_LOOPS = 3;
    const isDesktop = window.innerWidth >= 1024;
    const canvasDesktop = document.getElementById('hacker-canvas') as HTMLCanvasElement;
    const canvasMobile = document.getElementById('hacker-canvas-mobile') as HTMLCanvasElement;
    const ctxDesktop = canvasDesktop.getContext('2d')!;
    const ctxMobile = canvasMobile.getContext('2d')!;
    const section = document.getElementById('scroll-section');
    const track = isDesktop ? document.getElementById('articles-track') : null;

    const frames: HTMLImageElement[] = [];

    const audio = new Audio('/hacker-audio.m4a');
    audio.loop = false;
    audio.preload = 'auto';
    audio.volume = 0.5;
    let audioStarted = false;

    function drawFrame(index: number) {
      const img = frames[index];
      if (img && img.complete && img.naturalWidth > 0) {
        ctxDesktop.clearRect(0, 0, canvasDesktop.width, canvasDesktop.height);
        ctxDesktop.drawImage(img, 0, 0, canvasDesktop.width, canvasDesktop.height);
        ctxMobile.clearRect(0, 0, canvasMobile.width, canvasMobile.height);
        ctxMobile.drawImage(img, 0, 0, canvasMobile.width, canvasMobile.height);
      }
    }

    if (isDesktop && section && track) {
      // --- DESKTOP: fixed canvas + scroll-driven articles ---
      const viewportArticleHeight = window.innerHeight - 140;
      const articleScrollNeeded = track.scrollHeight - viewportArticleHeight;
      section.style.height = (articleScrollNeeded + window.innerHeight) + 'px';

      const endTop = 64;

      canvasDesktop.style.position = 'fixed';
      canvasDesktop.style.right = (window.innerWidth / 2 - 480 - 32) + 'px';
      canvasDesktop.style.top = endTop + 'px';
      canvasDesktop.style.zIndex = '10';
      canvasDesktop.style.pointerEvents = 'none';
      canvasDesktop.style.opacity = '0';
      canvasDesktop.style.transition = 'opacity 0.3s';

      function onScrollDesktop() {
        const rect = section!.getBoundingClientRect();
        // Show canvas only when scroll-section is at the top (articles visible)
        canvasDesktop.style.opacity = rect.top <= endTop ? '1' : '0';

        const scrollTop = Math.max(0, -rect.top);
        const maxScroll = section!.offsetHeight - window.innerHeight;
        if (maxScroll <= 0) return;
        const progress = Math.min(1, scrollTop / maxScroll);

        const maxOffset = track!.scrollHeight - viewportArticleHeight;
        const articleProgress = Math.min(1, scrollTop / articleScrollNeeded);
        track!.style.transform = `translateY(-${articleProgress * maxOffset}px)`;

        const frameProgress = (progress * VIDEO_LOOPS) % 1;
        const frameIndex = Math.floor(frameProgress * FRAME_COUNT) % FRAME_COUNT;
        drawFrame(frameIndex);

        if (audioStarted) {
          const targetTime = frameProgress * AUDIO_DURATION;
          if (Math.abs(audio.currentTime - targetTime) > 0.15) {
            audio.currentTime = targetTime;
          }
        }
      }

      window.addEventListener('scroll', () => {
        const inSection = section.getBoundingClientRect().top <= 0;
        if (!audioStarted && inSection) {
          audio.play().then(() => { audioStarted = true; }).catch(() => {});
        }
        if (audioStarted && inSection && audio.paused) audio.play().catch(() => {});
        if (audioStarted && !inSection && !audio.paused) audio.pause();
        clearTimeout((window as any).__hackerPause);
        (window as any).__hackerPause = setTimeout(() => {
          if (audioStarted && !audio.paused) audio.pause();
        }, 200);
      }, { passive: true });

      window.addEventListener('scroll', onScrollDesktop, { passive: true });
      onScrollDesktop();

    } else {
      // --- MOBILE: static canvas, simple scroll animation + audio ---

      function onScrollMobile() {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight <= 0) return;
        const progress = window.scrollY / docHeight;
        const frameProgress = (progress * VIDEO_LOOPS) % 1;
        const frameIndex = Math.floor(frameProgress * FRAME_COUNT) % FRAME_COUNT;
        drawFrame(frameIndex);

        if (audioStarted) {
          const targetTime = frameProgress * AUDIO_DURATION;
          if (Math.abs(audio.currentTime - targetTime) > 0.15) {
            audio.currentTime = targetTime;
          }
        }
      }

      window.addEventListener('scroll', () => {
        if (!audioStarted && window.scrollY > 50) {
          audio.play().then(() => { audioStarted = true; }).catch(() => {});
        }
        if (audioStarted && window.scrollY > 50 && audio.paused) audio.play().catch(() => {});
        if (audioStarted && window.scrollY <= 50 && !audio.paused) audio.pause();
        clearTimeout((window as any).__hackerPause);
        (window as any).__hackerPause = setTimeout(() => {
          if (audioStarted && !audio.paused) audio.pause();
        }, 200);
      }, { passive: true });

      window.addEventListener('scroll', onScrollMobile, { passive: true });
      onScrollMobile();
    }

    for (let i = 1; i <= FRAME_COUNT; i++) {
      const img = new Image();
      img.src = `/hacker-frames/frame_${String(i).padStart(3, '0')}.avif`;
      if (i === 1) img.onload = () => drawFrame(0);
      frames.push(img);
    }
  </script>

  <!-- JSON-LD WebSite + Organization -->
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Rentier Digital",
      url: "https://rentierdigital.xyz",
      description: "Tools, methods, and guides to ship real products with AI.",
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Rentier Digital",
      url: "https://rentierdigital.xyz",
      logo: {
        "@type": "ImageObject",
        url: "https://rentierdigital.xyz/favicon.png",
      },
      sameAs: [
        "https://x.com/rentierdigital",
        "https://medium.com/@rentierdigital",
        "https://dev.to/rentierdigital",
        "https://rentierdigital.hashnode.dev",
      ],
    },
  ])} />
</BaseLayout>
