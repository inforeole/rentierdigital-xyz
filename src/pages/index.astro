---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getBlogList } from "../lib/convex";

const articles = await getBlogList();
articles.sort(
  (a, b) =>
    new Date(b.published_date ?? 0).getTime() -
    new Date(a.published_date ?? 0).getTime()
);
const latest = articles.slice(0, 6);
---

<BaseLayout
  title="Rentier Digital — Build with AI"
  description="Tools, methods, and guides to ship real products with AI. From prompt engineering to production."
>
  <!-- Hero -->
  <section class="py-16 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
      Build real products<br />
      <span class="text-blue-400">with AI</span>
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-neutral-400">
      Guides, tools, and methods for solo builders and non-technical founders
      who want to ship — not just prototype.
    </p>
    <div class="mt-8 flex justify-center gap-4">
      <a
        href="/blog"
        class="rounded-md bg-white px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-neutral-200"
      >
        Read the blog
      </a>
      <a
        href="/tools"
        class="rounded-md border border-white/20 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:border-white/40"
      >
        Explore tools
      </a>
    </div>
  </section>

  <!-- Latest articles -->
  {
    latest.length > 0 && (
      <section class="py-8">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-semibold text-white">Latest articles</h2>
          <a
            href="/blog"
            class="text-sm text-neutral-400 transition-colors hover:text-white"
          >
            View all &rarr;
          </a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {latest.map((article) => (
            <ArticleCard
              title={article.title}
              slug={article.slug}
              hook={article.hook_first_lines}
              themes={article.themes}
              publishedDate={article.published_date}
              readTime={article.read_time_minutes}
              lang="en"
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- JSON-LD WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Rentier Digital",
    url: "https://rentierdigital.xyz",
    description:
      "Tools, methods, and guides to ship real products with AI.",
  })} />
</BaseLayout>
