---
import "../../styles/global.css";

const convexUrl = import.meta.env.PUBLIC_CONVEX_ACTIONS_URL || "";
const qrTrackUrl = `${convexUrl}/api/qr/track`;
const reviewUrl = `${convexUrl}/api/book-review/feedback`;
const SLUG = "rentier-ia-avis";
---

<!doctype html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>Le livre t'a aidé ? — Rentier Digital IA</title>
    <meta name="description" content="Ton retour sur Rentier Digital IA (2e édition 2026)." />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="min-h-screen bg-[#0a0a0a] text-neutral-200 antialiased flex flex-col items-center justify-center px-4 py-8">
    <div class="w-full max-w-[540px] bg-[#161616] border border-neutral-800 rounded-xl p-8 text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-wider text-violet-400 bg-violet-400/10 border border-violet-400/20 rounded-full px-3 py-1 mb-5">
        Rentier Digital IA · 2e édition
      </span>

      <!-- Vue 1 : choix du pouce -->
      <div id="view-rating">
        <h1 class="text-2xl font-bold text-white mb-3 leading-tight">Le livre t'a aidé à lancer ta rente digitale ?</h1>
        <p class="text-[0.95rem] leading-relaxed text-neutral-400 mb-6">
          Choisis un pouce. Ça prend 2 secondes.
        </p>

        <div class="grid grid-cols-2 gap-3">
          <button
            id="btn-up"
            type="button"
            class="flex flex-col items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-lg py-6 transition-colors"
          >
            <span class="text-3xl">👍</span>
            <span class="text-sm">Oui, ça m'a aidé</span>
          </button>
          <button
            id="btn-down"
            type="button"
            class="flex flex-col items-center justify-center gap-2 bg-rose-600 hover:bg-rose-500 text-white font-semibold rounded-lg py-6 transition-colors"
          >
            <span class="text-3xl">👎</span>
            <span class="text-sm">Pas vraiment</span>
          </button>
        </div>
      </div>

      <!-- Vue 2 : formulaire de retour (pouce bas) -->
      <div id="view-feedback" class="hidden">
        <h1 class="text-2xl font-bold text-white mb-3 leading-tight">Qu'est-ce qui a coincé ?</h1>
        <p class="text-[0.95rem] leading-relaxed text-neutral-400 mb-5">
          Sois franc. Je lis chaque réponse.
        </p>
        <textarea
          id="feedback-text"
          rows="5"
          maxlength="2000"
          placeholder="Quelque chose de précis — un chapitre flou, une méthode qui n'a pas pris, un sujet manquant…"
          class="w-full bg-[#0a0a0a] border border-neutral-700 rounded-lg p-3 text-sm text-neutral-200 placeholder-neutral-500 focus:outline-none focus:border-violet-500 mb-4"
        ></textarea>
        <button
          id="btn-submit-feedback"
          type="button"
          class="block w-full text-center font-semibold text-white bg-violet-600 hover:bg-violet-700 rounded-lg py-3.5 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Envoyer mon retour
        </button>
        <button
          id="btn-skip-feedback"
          type="button"
          class="block w-full mt-2 text-center text-sm text-neutral-500 hover:text-neutral-300 underline-offset-2 hover:underline transition-colors"
        >
          Passer, enregistre juste le pouce bas
        </button>
      </div>

      <!-- Vue 3 : remerciement -->
      <div id="view-thanks" class="hidden">
        <div class="text-5xl mb-4">🙏</div>
        <h1 class="text-2xl font-bold text-white mb-3 leading-tight">Merci !</h1>
        <p class="text-[0.95rem] leading-relaxed text-neutral-400" id="thanks-msg">
          Ton retour est bien arrivé. Ça aide vraiment.
        </p>
      </div>

      <!-- Vue 3 bis : encouragement avant Amazon (pouce haut) -->
      <div id="view-encourage" class="hidden">
        <div class="text-5xl mb-4">🙏</div>
        <h1 class="text-2xl font-bold text-white mb-3 leading-tight">Merci, ça compte vraiment</h1>
        <p class="text-[0.95rem] leading-relaxed text-neutral-400 mb-6">
          Pour un livre indépendant, un avis fait toute la différence : c'est lui qui le rend visible et qui aide d'autres lecteurs à le trouver. Si vous avez trente secondes, laissez une note et quelques mots sur Amazon. Même court, votre avis pèse bien plus que vous ne l'imaginez.
        </p>
        <a
          id="btn-encourage-cta"
          href="#"
          target="_blank"
          rel="noopener"
          class="block w-full text-center font-semibold text-white bg-emerald-600 hover:bg-emerald-500 rounded-lg py-3.5 transition-colors no-underline"
        >
          Laisser mon avis sur Amazon
        </a>
        <p class="mt-3 text-xs text-neutral-500">
          Vous serez redirigé vers la page du livre.
        </p>
      </div>

      <!-- Vue 4 : erreur -->
      <div id="view-error" class="hidden">
        <h1 class="text-2xl font-bold text-rose-400 mb-3">Quelque chose a planté.</h1>
        <p class="text-sm text-neutral-400 mb-4" id="error-msg">Réessaie dans un instant.</p>
        <button
          id="btn-retry"
          type="button"
          class="text-sm text-violet-400 hover:text-violet-300 underline"
        >
          Recharger
        </button>
      </div>
    </div>

    <!-- Bloc newsletter -->
    <div class="w-full max-w-[540px] mt-4 bg-gradient-to-br from-emerald-950/60 to-emerald-900/30 border border-emerald-700/30 rounded-xl p-6">
      <div class="flex items-center gap-5">
        <img src="/prompt-contracts-cover-thumb.avif" alt="Rentier Digital" class="w-20 h-auto rounded-md shadow-lg flex-shrink-0" />
        <div class="text-left">
          <h2 class="text-lg font-bold text-emerald-300 mb-1">Construire avec intention</h2>
          <p class="text-sm text-neutral-400 mb-3">
            Chaque semaine : outils IA, build en solo, et comment livrer plus vite. Sans blabla.
          </p>
          <a
            href="https://rentierdigital.beehiiv.com"
            class="inline-block font-semibold text-white bg-emerald-600 hover:bg-emerald-500 rounded-lg px-6 py-2.5 transition-colors no-underline text-sm"
            target="_blank"
            rel="noopener"
          >
            S'abonner — c'est gratuit
          </a>
        </div>
      </div>
    </div>

    <p class="mt-5 text-xs text-neutral-400">&copy; rentierdigital</p>

    <script define:vars={{ qrTrackUrl, reviewUrl, SLUG }}>
      // Track scan
      fetch(qrTrackUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug: SLUG }),
      }).catch(function () {});

      const views = {
        rating: document.getElementById("view-rating"),
        feedback: document.getElementById("view-feedback"),
        thanks: document.getElementById("view-thanks"),
        encourage: document.getElementById("view-encourage"),
        error: document.getElementById("view-error"),
      };

      function show(name) {
        Object.entries(views).forEach(function (entry) {
          entry[1].classList.toggle("hidden", entry[0] !== name);
        });
      }

      function showError(msg) {
        document.getElementById("error-msg").textContent = msg || "Réessaie dans un instant.";
        show("error");
      }

      async function postFeedback(rating, feedback) {
        const res = await fetch(reviewUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ slug: SLUG, rating: rating, feedback: feedback }),
        });
        if (!res.ok) {
          const text = await res.text().catch(function () { return ""; });
          throw new Error("HTTP " + res.status + (text ? ": " + text : ""));
        }
        return res.json();
      }

      document.getElementById("btn-up").addEventListener("click", async function () {
        const btn = this;
        btn.disabled = true;
        btn.textContent = "...";
        try {
          const data = await postFeedback("up");
          if (data && data.redirect_url) {
            // On enregistre le pouce haut, puis on laisse le lecteur cliquer
            // lui-même vers Amazon (pas de redirection sèche).
            document.getElementById("btn-encourage-cta").setAttribute("href", data.redirect_url);
            show("encourage");
          } else {
            document.getElementById("thanks-msg").textContent = "Content que ça t'ait aidé !";
            show("thanks");
          }
        } catch (err) {
          showError(err && err.message ? err.message : "Erreur réseau");
        }
      });

      document.getElementById("btn-down").addEventListener("click", function () {
        show("feedback");
      });

      document.getElementById("btn-submit-feedback").addEventListener("click", async function () {
        const btn = this;
        const text = (document.getElementById("feedback-text").value || "").trim();
        btn.disabled = true;
        btn.textContent = "Envoi…";
        try {
          await postFeedback("down", text || undefined);
          document.getElementById("thanks-msg").textContent = text
            ? "Bien reçu — tes notes sont enregistrées."
            : "Bien reçu — pouce bas enregistré.";
          show("thanks");
        } catch (err) {
          btn.disabled = false;
          btn.textContent = "Envoyer mon retour";
          showError(err && err.message ? err.message : "Erreur réseau");
        }
      });

      document.getElementById("btn-skip-feedback").addEventListener("click", async function () {
        try {
          await postFeedback("down");
          document.getElementById("thanks-msg").textContent = "Bien reçu — pouce bas enregistré.";
          show("thanks");
        } catch (err) {
          showError(err && err.message ? err.message : "Erreur réseau");
        }
      });

      document.getElementById("btn-retry").addEventListener("click", function () {
        location.reload();
      });
    </script>
  </body>
</html>
