---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Not Found" description="Page not found.">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="text-6xl font-bold text-white">404</h1>
    <p class="mt-4 text-lg text-neutral-400">This page doesn't exist.</p>
    <a
      href="/"
      class="mt-8 rounded-md bg-white px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-neutral-200"
    >
      Back to home
    </a>
  </div>
</BaseLayout>
