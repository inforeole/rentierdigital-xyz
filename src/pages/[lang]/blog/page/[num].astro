---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import ArticleCard from "../../../../components/ArticleCard.astro";
import Pagination from "../../../../components/Pagination.astro";
import { getBlogList } from "../../../../lib/convex";

export async function getStaticPaths() {
  const LOCALES = ["fr", "es", "de"];
  const PAGE_SIZE = 12;
  const paths = [];
  for (const lang of LOCALES) {
    const articles = await getBlogList(lang.toUpperCase());
    const totalPages = Math.ceil(articles.length / PAGE_SIZE);
    for (let i = 2; i <= totalPages; i++) {
      paths.push({ params: { lang, num: String(i) } });
    }
  }
  return paths;
}

const { lang, num } = Astro.params;
const currentPage = Number(num);
const PAGE_SIZE = 12;

const articles = await getBlogList(lang!.toUpperCase());
const sortDate = (a: (typeof articles)[0]) =>
  a.published_date ? new Date(a.published_date).getTime() : a._creationTime;
articles.sort((a, b) => sortDate(b) - sortDate(a));

const totalPages = Math.ceil(articles.length / PAGE_SIZE);
const start = (currentPage - 1) * PAGE_SIZE;
const pageArticles = articles.slice(start, start + PAGE_SIZE);
---

<BaseLayout
  title={`Blog — Page ${currentPage} — Rentier Digital`}
  description="Articles on building with AI, prompt engineering, solo building, and shipping real products."
  lang={lang}
>
  <h1 class="mb-8 text-3xl font-bold text-white">Blog</h1>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {pageArticles.map((article) => (
      <ArticleCard
        title={article.title}
        slug={article.slug}
        hook={article.hook_first_lines}
        tags={article.tags}
        publishedDate={article.published_date}
        readTime={article.read_time_minutes}
        lang={lang}
      />
    ))}
  </div>

  <Pagination currentPage={currentPage} totalPages={totalPages} basePath={`/${lang}/blog`} />
</BaseLayout>
