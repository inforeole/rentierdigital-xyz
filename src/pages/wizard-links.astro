---
// Hors-sitemap, hors-layout — page ressources link-in-bio
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>Ressources — Rentier Digital</title>
    <meta name="description" content="Formations et ressources recommandées par Rentier Digital." />
    <meta name="robots" content="noindex, nofollow" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        background: #0a0a0a;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: #f0f0f0;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 28px 16px 48px;
      }
      .wrap {
        width: 100%;
        max-width: 420px;
        display: flex;
        flex-direction: column;
      }

      /* Header */
      .header {
        text-align: center;
        padding-bottom: 28px;
      }
      .avatar {
        width: 68px; height: 68px;
        border-radius: 50%;
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 12px;
        font-size: 28px;
        box-shadow: 0 0 0 3px #141414, 0 0 0 5px #22c55e44;
      }
      .handle {
        font-size: 16px;
        font-weight: 700;
        letter-spacing: -0.2px;
      }
      .tagline {
        font-size: 13px;
        color: #6b7280;
        margin-top: 4px;
      }
      .ref-badge {
        display: none;
        align-items: center;
        gap: 6px;
        margin: 10px auto 0;
        width: fit-content;
        background: #0f1f12;
        border: 1px solid #22c55e33;
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 11px;
        font-weight: 600;
        color: #22c55e;
      }
      .ref-badge.show { display: flex; }
      .ref-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #22c55e;
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }

      /* Section label */
      .label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #3f3f46;
        margin-bottom: 8px;
      }

      /* CTA cards */
      .cards {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 20px;
      }
      .card {
        display: flex;
        align-items: center;
        gap: 14px;
        border-radius: 14px;
        padding: 16px;
        text-decoration: none;
        color: inherit;
        transition: transform .13s, opacity .13s;
        -webkit-tap-highlight-color: transparent;
      }
      .card:active { transform: scale(0.97); opacity: .9; }

      .card-primary {
        background: linear-gradient(135deg, #14532d 0%, #052e16 100%);
        border: 1px solid #22c55e44;
        box-shadow: 0 2px 20px #22c55e18;
      }
      .card-free {
        background: #141414;
        border: 1px solid #222;
      }

      .icon {
        width: 46px; height: 46px;
        border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
      }
      .card-primary .icon { background: #052e16; }
      .card-free .icon { background: #1c1c1c; }

      .info { flex: 1; min-width: 0; }
      .meta {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 2px;
      }
      .meta-text {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      .card-primary .meta-text { color: #86efac; }
      .card-free .meta-text { color: #52525b; }

      .badge {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        padding: 1px 6px;
        border-radius: 4px;
      }
      .badge-free { background: #1e3a5f33; color: #60a5fa; border: 1px solid #1e3a5f55; }
      .badge-sel { background: #78350f33; color: #fbbf24; border: 1px solid #78350f55; }

      .title {
        font-size: 15px;
        font-weight: 700;
        line-height: 1.25;
      }
      .sub {
        font-size: 12px;
        margin-top: 2px;
        line-height: 1.3;
      }
      .card-primary .sub { color: #4ade8088; }
      .card-free .sub { color: #52525b; }

      .arrow { font-size: 18px; flex-shrink: 0; color: #3f3f46; }
      .card-primary .arrow { color: #4ade80aa; }

      hr { border: none; border-top: 1px solid #1c1c1c; margin: 4px 0 16px; }

      footer {
        text-align: center;
        margin-top: 24px;
        font-size: 12px;
        color: #27272a;
      }
      footer a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="header">
        <div class="avatar">💰</div>
        <div class="handle">Rentier Digital</div>
        <div class="tagline">IA · revenus · business en ligne</div>
        <div class="ref-badge" id="refBadge">
          <div class="ref-dot"></div>
          <span id="refLabel">via YouTube</span>
        </div>
      </div>

      <div class="label">Formation recommandée</div>
      <div class="cards">
        <a class="card card-primary" id="link-wizard" href="/go/wizard">
          <div class="icon">🎓</div>
          <div class="info">
            <div class="meta">
              <span class="meta-text">Wizard Academy</span>
              <span class="badge badge-sel">sélection</span>
            </div>
            <div class="title">Postuler à la formation</div>
            <div class="sub">Candidature gratuite · places limitées</div>
          </div>
          <div class="arrow">→</div>
        </a>
      </div>

      <hr />
      <div class="label">Formations gratuites</div>
      <div class="cards">
        <a class="card card-free" id="link-vdl" href="/go/vdl">
          <div class="icon">🔗</div>
          <div class="info">
            <div class="meta">
              <span class="meta-text">Vente de liens</span>
              <span class="badge badge-free">gratuit</span>
            </div>
            <div class="title">Formation vente de liens</div>
            <div class="sub">Monétiser ton site avec des liens sponsorisés</div>
          </div>
          <div class="arrow">→</div>
        </a>

        <a class="card card-free" id="link-affiliation" href="/go/affiliation">
          <div class="icon">💸</div>
          <div class="info">
            <div class="meta">
              <span class="meta-text">Affiliation</span>
              <span class="badge badge-free">gratuit</span>
            </div>
            <div class="title">Formation affiliation</div>
            <div class="sub">Générer des commissions sans créer de produit</div>
          </div>
          <div class="arrow">→</div>
        </a>
      </div>

      <footer><a href="/">rentierdigital.xyz</a></footer>
    </div>

    <script>
      const ref = new URLSearchParams(location.search).get('ref') || '';
      const LABELS: Record<string, string> = { x: 'via X / Twitter', yt: 'via YouTube' };
      if (LABELS[ref]) {
        const badge = document.getElementById('refBadge')!;
        badge.classList.add('show');
        document.getElementById('refLabel')!.textContent = LABELS[ref];
      }
      const suffix = ref ? '?ref=' + encodeURIComponent(ref) : '';
      (['wizard', 'vdl', 'affiliation'] as const).forEach(slug => {
        const el = document.getElementById('link-' + slug) as HTMLAnchorElement | null;
        if (el) el.href = '/go/' + slug + suffix;
      });
    </script>
  </body>
</html>
