---
import BaseLayout from "../../layouts/BaseLayout.astro";

const tools = [
  {
    title: "Prompt Contracts — The Book",
    description:
      "A solo developer's framework for shipping production software with AI. Stop vibe coding, start contractualizing what you expect.",
    status: "available" as const,
    href: "/prompt-contract",
    cover: "/prompt-contracts-cover-thumb.avif",
  },
  {
    title: "Templates & Starter Kits",
    description:
      "Ready-to-use skills, prompts, and project starters for solo builders shipping with AI.",
    status: "coming" as const,
  },
  {
    title: "Newsletter",
    description:
      "Weekly insights on building with AI, curated tools, and real-world case studies.",
    status: "coming" as const,
  },
  {
    title: "CTO Services",
    description:
      "Technical co-founding, architecture, and hands-on development for non-technical founders.",
    status: "coming" as const,
  },
];
---

<BaseLayout
  title="Tools — Rentier Digital"
  description="Tools and methods to build real products with AI. Prompt Contract, templates, newsletter, and CTO services."
>
  <section class="py-8 text-center">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">Build with AI</h1>
    <p class="mx-auto mt-3 max-w-lg text-neutral-400">
      Tools and methods for solo builders and non-technical founders.
    </p>
  </section>

  <div class="grid gap-6 sm:grid-cols-2">
    {
      tools.map((tool) => (
        <div class="rounded-lg border border-white/10 p-6 transition-colors hover:border-white/20">
          <div class="flex gap-4">
            {tool.cover && (
              <img src={tool.cover} alt={tool.title} class="w-20 flex-shrink-0 rounded-md" width="80" height="115" />
            )}
            <div>
              <div class="mb-3 flex items-center gap-2">
                <h2 class="text-lg font-semibold text-white">{tool.title}</h2>
                {tool.status === "coming" && (
                  <span class="rounded-full bg-white/5 px-2 py-0.5 text-xs text-neutral-400">
                    Coming soon
                  </span>
                )}
              </div>
              <p class="text-sm text-neutral-400">{tool.description}</p>
              {tool.status === "available" && tool.href && (
                <a
                  href={tool.href}
                  class="mt-4 inline-block text-sm text-blue-400 transition-colors hover:text-blue-300"
                >
                  Learn more &rarr;
                </a>
              )}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</BaseLayout>
